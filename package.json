{
  "name": "claude-code-subscription-provider",
  "version": "1.0.0",
  "description": "Claude Code subscription provider for pi plus a subscription-compatible network interceptor",
  "main": "src/claude-network-interceptor.js",
  "scripts": {
    "interceptor": "node src/claude-network-interceptor.js",
    "demo:hello": "node src/claude-network-interceptor.js --exec claude -- --print \"Hello world\""
  },
  "keywords": [
    "claude",
    "proxy",
    "interceptor",
    "subscription",
    "mitm",
    "pi-package"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "pi": {
    "extensions": [
      "./.pi/extensions/claude-code-subscription-provider"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "http-mitm-proxy": "^1.1.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
